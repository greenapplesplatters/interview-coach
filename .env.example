# Rename this file to .env.local for local development.
# For Vercel deployment, set these in your project's Environment Variables dashboard.

# ── AI Provider ───────────────────────────────────────────────────────────────
# Set ONE provider and its corresponding API key.
# If AI_PROVIDER is omitted, the app auto-detects from whichever key is present.
#
# Valid values: gemini | openai | anthropic
# AI_PROVIDER=gemini

# Optional: override the default model for your chosen provider.
# Defaults: gemini    → gemini-3.1-flash-lite-preview
#           openai    → gpt-4o-mini
#           anthropic → claude-haiku-4-5-20251001
# AI_MODEL=gpt-4o

# ── API Keys ──────────────────────────────────────────────────────────────────
# Uncomment and fill in the key for your chosen provider.

GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
